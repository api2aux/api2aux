{
  "name": "api2aux-monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @api2aux/app dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:run": "pnpm -r test:run"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "express-rate-limit@>=8.2.0 <8.2.2": "8.3.2"
    }
  }
}
